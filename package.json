{
  "name": "tidal-cli",
  "version": "0.1.0",
  "description": "Tidal music API CLI and MCP server",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26"
  },
  "bin": {
    "tidal": "./dist/bin/cli.js",
    "tidal-mcp": "./dist/bin/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:cli": "node --strip-types bin/cli.ts",
    "dev:mcp": "node --strip-types bin/mcp-server.ts",
    "test": "node --strip-types --test 'src/**/*.test.ts'",
    "test:coverage": "node --strip-types --test --experimental-test-coverage 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tidal-music/api": "^0.34.0",
    "@tidal-music/auth": "^1.6.1",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
