{
  "name": "tidal-cli",
  "version": "0.1.0",
  "description": "Tidal music API CLI and MCP server",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "tidal": "./dist/bin/cli.js",
    "tidal-mcp": "./dist/bin/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:cli": "node --strip-types bin/cli.ts",
    "dev:mcp": "node --strip-types bin/mcp-server.ts",
    "test": "node --strip-types --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tidal-music/api": "^0.15.0",
    "@tidal-music/auth": "^1.6.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2"
  }
}
